# Security Settings
SECRET_KEY=django-insecure-your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=ccbwebremasterv2.onrender.com,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://ccbwebremasterv2.onrender.com

# Caching Infrastructure (Optional - defaults to memory cache)
REDIS_URL=redis://127.0.0.1:6379/0

# Database Settings
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
DATABASE_CONN_MAX_AGE=600
DATABASE_CONN_HEALTH_CHECKS=True

# Cloudinary Settings (Optional - if set, enables cloud-backed persistent uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=

# Google reCAPTCHA v2 (get keys at https://www.google.com/recaptcha/admin)
RECAPTCHA_PUBLIC_KEY=your-recaptcha-site-key-here
RECAPTCHA_PRIVATE_KEY=your-recaptcha-secret-key-here

# Email Settings
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=City College of Bayawan <no-reply@citycollegeofbayawan.edu.ph>
CONTACT_INQUIRY_RECIPIENT=citycollegeofbayawan@gmail.com
